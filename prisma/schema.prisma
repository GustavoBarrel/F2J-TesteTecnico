// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String                  @id @default(uuid())
  firstName              String
  lastName               String
  email                  String                  @unique
  username               String                  @unique
  password               String
  isGlobalAdmin          Boolean                 @default(false)
  isActive               Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  userSectorMemberships  UserSectorMembership[]
  createdRequests        Request[]               @relation("CreatedByUser")
  requestAssignments     RequestAssignee[]
  observedRequests       RequestObserver[]
  requestMessages        RequestMessage[]
  requestHistories       RequestHistory[]
  updatedAutoCompleteSettings RequestAutoCompleteSetting[]
  passwordResetCodes     PasswordResetCode[]

  @@map("users")
}

model PasswordResetCode {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  codeHash  String    @map("code_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("password_reset_codes")
}

model Sector {
  id                     String                  @id @default(uuid())
  name                   String                  @unique
  onlyManagerCanView     Boolean                 @default(true)
  onlyManagerCanEdit     Boolean                 @default(true)
  onlyManagerCanArchive  Boolean                 @default(true)
  isActive               Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  userSectorMemberships  UserSectorMembership[]
  sectorServices         SectorService[]
  requests               Request[]

  @@map("sectors")
}

model SectorService {
  id         String    @id @default(uuid())
  name       String
  isActive   Boolean   @default(true)
  sectorId   String    @map("sector_id")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  sector     Sector    @relation(fields: [sectorId], references: [id])
  requests   Request[]

  @@map("sector_services")
}

model UserSectorMembership {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  sectorId   String    @map("sector_id")
  roleId     String    @map("role_id")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user       User      @relation(fields: [userId], references: [id])
  sector     Sector    @relation(fields: [sectorId], references: [id])
  role       Role      @relation(fields: [roleId], references: [id])

  @@unique([userId, sectorId])
  @@map("user_sector_memberships")
}

model Role {
  id                      String                  @id @default(uuid())
  name                    String                  @unique
  description             String
  slug                    RoleSlug                @unique
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  userSectorMemberships   UserSectorMembership[]

  @@map("roles")
}

model Request {
  id               String           @id @default(uuid())
  title            String
  description      String
  status           RequestStatus    @default(NEW)
  priority         RequestPriority  @default(MEDIUM)
  sectorId         String           @map("sector_id")
  sectorServiceId  String           @map("sector_service_id")
  createdById      String           @map("created_by_id")
  solvedAt         DateTime?        @map("solved_at")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  sector           Sector           @relation(fields: [sectorId], references: [id])
  sectorService    SectorService    @relation(fields: [sectorServiceId], references: [id])
  createdBy        User             @relation("CreatedByUser", fields: [createdById], references: [id], onDelete: Restrict)
  assignees        RequestAssignee[]
  observers        RequestObserver[]
  messages         RequestMessage[]
  history          RequestHistory[]

  @@index([sectorId, status])
  @@index([status, solvedAt])
  @@index([createdById])
  @@map("requests")
}

model RequestAssignee {
  id         String   @id @default(uuid())
  requestId  String   @map("request_id")
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  request    Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@unique([requestId, userId])
  @@index([userId])
  @@map("request_assignees")
}

model RequestObserver {
  id         String   @id @default(uuid())
  requestId  String   @map("request_id")
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  request    Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@unique([requestId, userId])
  @@index([userId])
  @@map("request_observers")
}

model RequestMessage {
  id         String    @id @default(uuid())
  requestId  String    @map("request_id")
  authorId   String    @map("author_id")
  content    String
  createdAt  DateTime  @default(now())

  request    Request   @relation(fields: [requestId], references: [id])
  user       User      @relation(fields: [authorId], references: [id])

  @@map("request_messages")
}

model RequestHistory {
  id          String                @id @default(uuid())
  requestId   String                @map("request_id")
  userId      String                @map("user_id")
  action      RequestHistoryAction
  fromStatus  RequestStatus?
  toStatus    RequestStatus?
  metadata    Json?
  createdAt   DateTime              @default(now())

  request     Request               @relation(fields: [requestId], references: [id])
  user        User                  @relation(fields: [userId], references: [id])

  @@map("request_histories")
}

model pivotTable {
  id         String    @id @default(uuid())
  subjectType SubjectType
  subjectId  String    @map("subject_id")
  channel ChannelType
  status PivotStatus
  recipientId String    @map("recipient_id")
  metadata   Json?
  sentAt     DateTime? @map("sent_at")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("pivot_table")
}



enum SubjectType {
  USER
  SECTOR
  REQUEST
}

enum ChannelType {
  EMAIL
  SMS
  PUSH
  WHATSAPP
  IN_APP
}

enum PivotStatus {
  PENDING
  PROCESSING
  SENT
  DELIVERED
  FAILED
  RETRYING
  CANCELLED
  EXPIRED
}

enum RoleSlug {
  MANAGER
  TECHNICIAN
}

enum RequestStatus {
  NEW
  PENDING
  IN_PROGRESS
  SOLVED
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum RequestPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum RequestHistoryAction {
  CREATED
  UPDATED
  ASSIGNED
  REASSIGNED
  STATUS_CHANGED
  PRIORITY_CHANGED
  MESSAGE_SENT
  CANCELLED
  ARCHIVED
}

enum AutoCompleteDurationUnit {
  MINUTES
  DAYS
}

model RequestAutoCompleteSetting {
  id             String                   @id @default("default")
  cronExpression String                   @default("0 6 * * *") @map("cron_expression")
  durationValue  Int                      @default(1) @map("duration_value")
  durationUnit   AutoCompleteDurationUnit @default(DAYS) @map("duration_unit")
  updatedAt      DateTime                 @updatedAt @map("updated_at")
  updatedById    String?                  @map("updated_by_id")

  updatedBy      User?                    @relation(fields: [updatedById], references: [id])

  @@map("request_auto_complete_settings")
}
