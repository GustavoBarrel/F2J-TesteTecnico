# Copie para .env e ajuste os valores
# cp .env.example .env

DATABASE_URL="postgresql://usuario:senha@localhost:5432/central_servicos"
JWT_SECRET=gere_com_node_-e_"require('crypto').randomBytes(64).toString('hex')"

# Respostas de erro com bloco "debug" (stack, path, etc.) — usar apenas em dev local
DEBUG_API_RESPONSE=false

# E-mail (redefinição de senha) — sem SMTP_HOST o código é logado no console (dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ServiceHub <noreply@servicehub.local>"

# Auto-conclusão de SOLVED: configurada pelo admin em
# GET/PATCH /api/admin/settings/request-auto-complete
